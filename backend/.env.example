# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env en prod

# Serveur
PORT=2000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Base de données (MAMP local)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=ecommerce_dev

# JWT
JWT_SECRET=changeme_secret_tres_long_et_aleatoire

# Brevo (emails transactionnels)
# Clés dispo dans Brevo > Paramètres > SMTP & API
BREVO_SMTP_USER=your_brevo_email
BREVO_SMTP_KEY=your_brevo_smtp_key

# SumUp (paiement)
# Clés dispo dans SumUp Dashboard > Développeurs > Credentials
# SUMUP_API_KEY est prioritaire sur le flow OAuth (utiliser l'un ou l'autre)
SUMUP_API_KEY=your_sumup_api_key
SUMUP_CLIENT_ID=your_sumup_client_id
SUMUP_CLIENT_SECRET=your_sumup_client_secret
SUMUP_MERCHANT_CODE=your_sumup_merchant_code
SUMUP_WEBHOOK_SECRET=your_sumup_webhook_secret

# Sendcloud (livraison — tarifs, labels, points relais)
# Clés dispo dans Sendcloud > Paramètres > Intégrations > API
SENDCLOUD_PUBLIC_KEY=your_sendcloud_public_key
SENDCLOUD_SECRET_KEY=your_sendcloud_secret_key

# Adresse expéditeur (votre boutique)
SHOP_NAME=Ma Boutique
SHOP_ADDRESS_LINE1=1 rue de la Paix
SHOP_CITY=Paris
SHOP_POSTAL_CODE=75001
SHOP_COUNTRY_CODE=FR
