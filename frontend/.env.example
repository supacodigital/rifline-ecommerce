# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env en prod

# En dev : laisser VITE_API_URL vide — le proxy Vite (/api → localhost:2000) est utilisé automatiquement
# En prod sur O2switch : laisser aussi vide si frontend et backend sont sur le même domaine (rif-line.com)
# VITE_API_URL=https://rif-line.com/api
